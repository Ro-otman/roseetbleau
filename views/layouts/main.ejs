<!DOCTYPE html>
<html lang="fr">
  <%- include("../partials/head", { pageTitle, pageStylesheet }) %>
  <body class="is-loading">
    <div class="site-loader" data-site-loader role="status" aria-live="polite" aria-label="Chargement du site">
      <div class="site-loader__panel">
        <div class="site-loader__brand" aria-hidden="true">
          <span class="site-loader__rose">Rose</span>
          <span class="site-loader__amp">&amp;</span>
          <span class="site-loader__bleu">Bleu</span>
        </div>

        <div class="site-loader__steps" aria-hidden="true">
          <span class="site-loader__step site-loader__step--rose"></span>
          <span class="site-loader__step site-loader__step--blue"></span>
          <span class="site-loader__step site-loader__step--rose"></span>
          <span class="site-loader__step site-loader__step--blue"></span>
        </div>

        <p class="site-loader__text">Chargement de la boutique...</p>
        <span class="site-loader__line" aria-hidden="true"></span>
      </div>
    </div>

    <%- include("../partials/header", { currentPath, authUser }) %>

    <main class="site-main">
      <%- body %>
    </main>

    <%- include("../partials/footer") %>
    <%- include("../partials/nav", { currentPath, navClass: "main-nav main-nav--mobile", includeSearch: true }) %>
    <script src="/js/script.js" defer></script>
  </body>
</html>
