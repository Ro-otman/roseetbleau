<section class="user-page page-details">
  <%
    const product = detailProduct || null;
    const gallery = Array.isArray(detailGallery) ? detailGallery : [];
    const characteristics = Array.isArray(detailCharacteristics) ? detailCharacteristics : [];
    const comfortPoints = Array.isArray(detailComfortPoints) ? detailComfortPoints : [];
    const deliveryInfos = Array.isArray(detailDeliveryInfos) ? detailDeliveryInfos : [];
    const reviews = Array.isArray(detailReviews) ? detailReviews : [];
    const sizes = Array.isArray(detailSizes) ? detailSizes : [];
    const colors = Array.isArray(detailColors) ? detailColors : [];
    const message = detailMessage || null;

    const fallbackMainImage = {
      src: "/images/hero-slide-1.svg",
      alt: "Produit Rose et Bleu",
    };

    const mainImage = gallery.length ? gallery[0] : fallbackMainImage;
    const detailsHref = product && product.href ? product.href : "/details";
    const badgeLabel = product
      ? product.oldPrice
        ? product.discountTag || "Promo"
        : product.tag || "Produit"
      : "";
    const reviewCount = product && Number.isFinite(Number(product.reviewCount))
      ? Number(product.reviewCount)
      : 0;
  %>

  <% if (message) { %>
  <article class="details-message details-message--<%= message.tone || 'info' %>">
    <h2><%= message.title || "Information" %></h2>
    <p><%= message.text || "" %></p>
    <a href="/shop">Retour au shop</a>
  </article>
  <% } %>

  <% if (!product) { %>
  <article class="details-empty">
    <h2>Aucune fiche produit a afficher</h2>
    <p>Ajoute un produit depuis l administration ou ouvre une fiche depuis la page shop.</p>
    <a href="/shop">Voir le catalogue</a>
  </article>
  <% } else { %>
  <section class="details-layout" aria-label="Contenu detail produit">
    <div class="details-scroll" aria-label="Photos et caracteristiques">
      <section class="details-gallery" aria-label="Galerie produit" data-details-gallery>
        <figure class="details-gallery__main">
          <img src="<%= mainImage.src %>" alt="<%= mainImage.alt %>" data-details-main-image />
          <span class="details-gallery__badge"><%= badgeLabel %></span>
          <span class="details-gallery__sku"><%= product.sku %></span>
        </figure>

        <div class="details-gallery__thumbs">
          <% gallery.forEach((item, idx) => { %>
          <a
            class="details-thumb <%= idx === 0 ? 'is-active' : '' %>"
            href="<%= detailsHref %>"
            data-details-thumb
            data-image-src="<%= item.src %>"
            data-image-alt="<%= item.alt %>"
            aria-current="<%= idx === 0 ? 'true' : 'false' %>"
          >
            <img src="<%= item.src %>" alt="<%= item.alt %>" />
            <span><%= item.label %></span>
          </a>
          <% }) %>
        </div>

        <article class="details-photo-summary" aria-label="Resume fiche produit">
          <p class="details-photo-summary__kicker">Fiche produit</p>
          <h1 class="details-photo-summary__title"><%= product.name %></h1>
          <p class="details-photo-summary__text"><%= product.shortDescription %></p>
          <div class="details-photo-summary__meta">
            <p><i class="bx bxs-star"></i><span><%= product.rating %> / 5 sur <%= reviewCount %> avis</span></p>
            <p><i class="bx bx-check-circle"></i><span><%= product.status %></span></p>
            <p><i class="bx bx-time-five"></i><span>Expedition 24-48h</span></p>
          </div>
        </article>
      </section>

      <section class="details-block" aria-label="Caracteristiques">
        <div class="details-block__head">
          <p class="details-block__kicker">Caracteristiques</p>
          <h2 class="details-block__title">Composition et points techniques</h2>
        </div>
        <ul class="details-feature-list">
          <% if (!characteristics.length) { %>
          <li>
            <i class="bx bx-info-circle"></i>
            <span>Informations detaillees indisponibles pour le moment.</span>
          </li>
          <% } %>

          <% characteristics.forEach((item) => { %>
          <li>
            <i class="bx bx-check-circle"></i>
            <span><%= item %></span>
          </li>
          <% }) %>
        </ul>
      </section>

      <section class="details-block" aria-label="Confort produit">
        <div class="details-block__head">
          <p class="details-block__kicker">Confort quotidien</p>
          <h2 class="details-block__title">Pourquoi cette piece plait autant</h2>
        </div>
        <div class="details-comfort-grid">
          <% comfortPoints.forEach((point) => { %>
          <article class="details-comfort-card">
            <span class="details-comfort-card__icon">
              <i class="bx <%= point.icon %>"></i>
            </span>
            <h3><%= point.title %></h3>
            <p><%= point.text %></p>
          </article>
          <% }) %>
        </div>
      </section>

      <section class="details-block" aria-label="Livraison et retours">
        <div class="details-block__head">
          <p class="details-block__kicker">Service</p>
          <h2 class="details-block__title">Livraison, suivi et retour</h2>
        </div>
        <div class="details-delivery-grid">
          <% deliveryInfos.forEach((item) => { %>
          <article class="details-delivery-card">
            <i class="bx <%= item.icon %>"></i>
            <h3><%= item.title %></h3>
            <p><%= item.text %></p>
          </article>
          <% }) %>
        </div>
      </section>

      <section class="details-block" aria-label="Avis clients">
        <div class="details-block__head">
          <p class="details-block__kicker">Retours clients</p>
          <h2 class="details-block__title">Avis verifies</h2>
        </div>
        <div class="details-review-grid">
          <% if (!reviews.length) { %>
          <article class="details-review-empty">
            <p>Pas encore d avis publie pour ce produit.</p>
          </article>
          <% } %>

          <% reviews.forEach((review) => { %>
          <article class="details-review-card">
            <p class="details-review-card__head">
              <span><%= review.author %></span>
              <strong>
                <i class="bx bxs-star"></i>
                <span><%= review.score %></span>
              </strong>
            </p>
            <p class="details-review-card__text"><%= review.text %></p>
          </article>
          <% }) %>
        </div>
      </section>
    </div>

    <aside class="details-static" aria-label="Achat produit">
      <article class="details-buy-card">
        <p class="details-buy-card__kicker"><%= product.status %> - livraison rapide</p>
        <h2 class="details-buy-card__title"><%= product.name %></h2>
        <p class="details-buy-card__subtitle">Categorie: <%= product.category %> | Age: <%= product.age %></p>

        <div class="details-buy-card__prices">
          <span class="details-buy-card__price-current"><%= product.price %></span>
          <% if (product.oldPrice) { %>
          <span class="details-buy-card__price-old"><%= product.oldPrice %></span>
          <% } %>
        </div>

        <div class="details-buy-card__rating">
          <i class="bx bxs-star"></i>
          <span><%= product.rating %> note moyenne sur <%= reviewCount %> avis</span>
        </div>

        <div class="details-buy-card__choice">
          <p class="details-buy-card__label">Taille</p>
          <div class="details-size-grid">
            <% sizes.forEach((sizeLabel, idx) => { %>
            <button type="button" class="details-size <%= idx === 0 ? 'is-active' : '' %>"><%= sizeLabel %></button>
            <% }) %>
          </div>
        </div>

        <div class="details-buy-card__choice">
          <p class="details-buy-card__label">Couleur</p>
          <div class="details-color-list">
            <% colors.forEach((color, idx) => { %>
            <button
              type="button"
              class="details-color <%= idx === 0 ? 'is-active' : '' %>"
              style="background:<%= color.hex %>;"
              aria-label="<%= color.label %>"
              title="<%= color.label %>"
            ></button>
            <% }) %>
          </div>
        </div>

        <div class="details-buy-card__choice">
          <p class="details-buy-card__label">Quantite</p>
          <div class="details-qty">
            <button type="button" aria-label="Diminuer">-</button>
            <span>1</span>
            <button type="button" aria-label="Augmenter">+</button>
          </div>
        </div>

        <div class="details-buy-card__actions">
          <a class="details-cta details-cta--cart" data-add-to-cart data-product-slug="<%= product.slug || '' %>" href="/cart">
            <i class="bx bx-cart-add"></i>
            <span>Ajouter au panier</span>
          </a>
          <button class="details-cta details-cta--pay" type="button">
            <i class="bx bx-credit-card-front"></i>
            <span>Payer maintenant</span>
          </button>
        </div>

        <button
          class="details-buy-card__wish"
          type="button"
          data-favorite-btn
          data-product-slug="<%= product.slug || '' %>"
          aria-pressed="<%= product.isFavorite ? 'true' : 'false' %>"
          aria-label="Ajouter <%= product.name %> aux favoris"
        >
          <i class="bx <%= product.isFavorite ? 'bxs-heart' : 'bx-heart' %>"></i>
          <span><%= product.isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris' %></span>
        </button>

        <ul class="details-buy-card__notes">
          <li><i class="bx bx-check"></i><span>Retours sous 14 jours</span></li>
          <li><i class="bx bx-check"></i><span>Paiement securise</span></li>
          <li><i class="bx bx-check"></i><span>Support client disponible</span></li>
        </ul>
      </article>

      <article class="details-help-card">
        <h3>Besoin d aide pour choisir ?</h3>
        <p>Notre equipe peut t aider pour la taille, la livraison et les conseils look.</p>
        <a href="/faq">Voir les questions frequentes</a>
      </article>
    </aside>
  </section>
  <% } %>
</section>
