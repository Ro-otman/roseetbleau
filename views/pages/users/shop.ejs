<section class="user-page page-shop">
  <%
    const filters = shopFilters || {};
    const selectedQuery = String(filters.q || "");
    const selectedCategory = String(filters.category || "");
    const selectedSort = String(filters.sort || "popular");
    const selectedSize = String(filters.size || "");
    const selectedPrice = String(filters.price || "");
    const promoOnly = Boolean(filters.promo);

    const products = Array.isArray(shopProducts) ? shopProducts : [];
    const categoriesFromDb = Array.isArray(shopCategories) ? shopCategories : [];
    const featuredCategories = Array.isArray(shopFeaturedCategories) ? shopFeaturedCategories : [];

    const totalProducts = Number(shopMeta?.totalProducts || 0);
    const filteredProducts = Number(shopMeta?.filteredProducts || products.length);
    const totalCategories = Number(shopMeta?.totalCategories || categoriesFromDb.length);

    const buildShopHref = (overrides = {}) => {
      const params = new URLSearchParams();

      const nextQuery = overrides.q !== undefined ? String(overrides.q || "") : selectedQuery;
      const nextCategory = overrides.category !== undefined ? String(overrides.category || "") : selectedCategory;
      const nextSort = overrides.sort !== undefined ? String(overrides.sort || "") : selectedSort;
      const nextPromo = overrides.promo !== undefined ? Boolean(overrides.promo) : promoOnly;
      const nextSize = overrides.size !== undefined ? String(overrides.size || "") : selectedSize;
      const nextPrice = overrides.price !== undefined ? String(overrides.price || "") : selectedPrice;

      if (nextQuery) params.set("q", nextQuery);
      if (nextCategory) params.set("category", nextCategory);
      if (nextSort && nextSort !== "popular") params.set("sort", nextSort);
      if (nextPromo) params.set("promo", "true");
      if (nextSize) params.set("size", nextSize);
      if (nextPrice) params.set("price", nextPrice);

      const queryString = params.toString();
      return queryString ? `/shop?${queryString}` : "/shop";
    };

    const quickFilters = [
      {
        label: "Tout le catalogue",
        href: buildShopHref({ q: "", category: "", sort: "popular", promo: false, size: "", price: "" }),
        active:
          !selectedQuery &&
          !selectedCategory &&
          !promoOnly &&
          !selectedSize &&
          !selectedPrice &&
          selectedSort === "popular",
      },
      { label: "Nouveautes", href: buildShopHref({ sort: "new" }), active: selectedSort === "new" },
      { label: "Bebes", href: buildShopHref({ category: "bebes", promo: false }), active: selectedCategory === "bebes" },
      { label: "Filles", href: buildShopHref({ category: "filles", promo: false }), active: selectedCategory === "filles" },
      { label: "Garcons", href: buildShopHref({ category: "garcons", promo: false }), active: selectedCategory === "garcons" },
      { label: "Chaussures", href: buildShopHref({ category: "chaussures", promo: false }), active: selectedCategory === "chaussures" },
      { label: "Accessoires", href: buildShopHref({ category: "accessoires", promo: false }), active: selectedCategory === "accessoires" },
      { label: "Promotions", href: buildShopHref({ promo: true }), active: promoOnly },
    ];

    const serviceHighlights = [
      {
        icon: "bx-rocket",
        title: "Expedition 24-48h",
        text: "Preparation rapide pour toutes les commandes validees.",
      },
      {
        icon: "bx-check-shield",
        title: "Paiement securise",
        text: "Transactions protegees et verification anti-fraude.",
      },
      {
        icon: "bx-refresh",
        title: "Retours faciles",
        text: "14 jours pour echanger ou retourner sereinement.",
      },
      {
        icon: "bx-support",
        title: "Support disponible",
        text: "Assistance client du lundi au samedi.",
      },
    ];

    const categories = [
      {
        label: "Tout",
        slug: "",
        count: totalProducts,
        href: buildShopHref({ category: "", promo: false }),
      },
      ...categoriesFromDb.map((category) => ({
        label: category.name,
        slug: category.slug,
        count: Number(category.count || 0),
        href: buildShopHref({ category: category.slug, promo: false }),
      })),
    ];

    const getCategoryIcon = (categoryName = "") => {
      const normalized = String(categoryName).toLowerCase();
      if (normalized.includes("bebe")) return "bx-gift";
      if (normalized.includes("fille")) return "bx-heart";
      if (normalized.includes("garcon")) return "bx-package";
      if (normalized.includes("chaussure")) return "bx-shield-quarter";
      if (normalized.includes("accessoire")) return "bx-purchase-tag-alt";
      if (normalized.includes("mixte")) return "bx-refresh";
      return "bx-star";
    };
  %>

  <section class="shop-hero" aria-label="Catalogue Rose et Bleu">
    <div class="shop-hero__content">
      <p class="shop-hero__kicker">Catalogue complet</p>
      <h1 class="shop-hero__title">Tous les produits Rose&amp;Bleu en un seul espace</h1>
      <p class="shop-hero__text">
        Explore toutes les categories: bebes, filles, garcons, chaussures et accessoires.
        Des pieces pensees pour le confort, la qualite et un style ludique au quotidien.
      </p>
      <div class="shop-hero__actions">
        <a class="btn btn-primary" href="<%= buildShopHref({ promo: true }) %>">Voir les promotions</a>
        <a class="btn btn-outline" href="/favoris">Mes favoris</a>
      </div>
      <div class="shop-hero__chips" aria-label="Filtres rapides">
        <% quickFilters.forEach((filter) => { %>
        <a class="shop-chip <%= filter.active ? 'is-active' : '' %>" href="<%= filter.href %>">
          <span><%= filter.label %></span>
        </a>
        <% }) %>
      </div>
    </div>

    <aside class="shop-hero__panel" aria-label="Resume catalogue">
      <article class="shop-hero__stat">
        <p class="shop-hero__value"><%= totalProducts %></p>
        <p class="shop-hero__label">references actives</p>
      </article>
      <article class="shop-hero__stat">
        <p class="shop-hero__value"><%= totalCategories %></p>
        <p class="shop-hero__label">categories principales</p>
      </article>
      <article class="shop-hero__stat">
        <p class="shop-hero__value">24-48h</p>
        <p class="shop-hero__label">preparation moyenne</p>
      </article>
      <a class="shop-hero__panel-cta" href="/details">Voir une fiche produit</a>
    </aside>
  </section>

  <section class="shop-services" aria-label="Avantages boutique">
    <% serviceHighlights.forEach((item) => { %>
    <article class="shop-service-card">
      <span class="shop-service-card__icon" aria-hidden="true">
        <i class="bx <%= item.icon %>"></i>
      </span>
      <h2><%= item.title %></h2>
      <p><%= item.text %></p>
    </article>
    <% }) %>
  </section>

  <section class="shop-sticky-filters" aria-label="Filtres rapides desktop">
    <div class="shop-sticky-filters__inner">
      <p class="shop-sticky-filters__label">
        <i class="bx bx-slider-alt"></i>
        <span>Filtres rapides</span>
      </p>

      <div class="shop-sticky-filters__list">
        <% quickFilters.forEach((filter) => { %>
        <a class="shop-sticky-filter <%= filter.active ? 'is-active' : '' %>" href="<%= filter.href %>">
          <span><%= filter.label %></span>
        </a>
        <% }) %>
        <a class="shop-sticky-filter shop-sticky-filter--ghost" href="<%= buildShopHref({ q: '', category: '', sort: 'popular', promo: false, size: '', price: '' }) %>">Reinitialiser</a>
      </div>
    </div>
  </section>

  <section class="shop-layout" aria-label="Listing produits et filtres">
    <aside id="shop-mobile-filters" class="shop-filters" data-shop-filters aria-label="Filtres shop">
      <div class="shop-filter-block">
        <p class="shop-filter-block__kicker">Affiner le catalogue</p>
        <h2 class="shop-filter-block__title">Filtres</h2>
      </div>

      <div class="shop-filter-block">
        <h3>Categories</h3>
        <ul class="shop-filter-list">
          <% categories.forEach((category) => { %>
          <li>
            <a
              class="shop-filter-link <%= category.slug === selectedCategory || (!selectedCategory && !category.slug) ? 'is-active' : '' %>"
              href="<%= category.href %>"
            >
              <span><%= category.label %></span>
              <strong><%= category.count %></strong>
            </a>
          </li>
          <% }) %>
        </ul>
      </div>

      <div class="shop-filter-block">
        <h3>Tailles</h3>
        <div class="shop-size-grid" aria-label="Tailles disponibles">
          <a href="<%= buildShopHref({ size: '1-2' }) %>" class="shop-size-chip <%= selectedSize === '1-2' ? 'is-active' : '' %>">1-2A</a>
          <a href="<%= buildShopHref({ size: '3-4' }) %>" class="shop-size-chip <%= selectedSize === '3-4' ? 'is-active' : '' %>">3-4A</a>
          <a href="<%= buildShopHref({ size: '5-6' }) %>" class="shop-size-chip <%= selectedSize === '5-6' ? 'is-active' : '' %>">5-6A</a>
          <a href="<%= buildShopHref({ size: '7-8' }) %>" class="shop-size-chip <%= selectedSize === '7-8' ? 'is-active' : '' %>">7-8A</a>
          <a href="<%= buildShopHref({ size: '9-10' }) %>" class="shop-size-chip <%= selectedSize === '9-10' ? 'is-active' : '' %>">9-10A</a>
          <a href="<%= buildShopHref({ size: '11-12' }) %>" class="shop-size-chip <%= selectedSize === '11-12' ? 'is-active' : '' %>">11-12A</a>
        </div>
      </div>

      <div class="shop-filter-block">
        <h3>Budget</h3>
        <div class="shop-budget-list" aria-label="Tranches de prix">
          <a class="<%= selectedPrice === '0-15' ? 'is-active' : '' %>" href="<%= buildShopHref({ price: '0-15' }) %>">Moins de 15 EUR</a>
          <a class="<%= selectedPrice === '15-30' ? 'is-active' : '' %>" href="<%= buildShopHref({ price: '15-30' }) %>">15 a 30 EUR</a>
          <a class="<%= selectedPrice === '30-45' ? 'is-active' : '' %>" href="<%= buildShopHref({ price: '30-45' }) %>">30 a 45 EUR</a>
          <a class="<%= selectedPrice === '45+' ? 'is-active' : '' %>" href="<%= buildShopHref({ price: '45+' }) %>">45 EUR et plus</a>
        </div>
      </div>

      <div class="shop-filter-block">
        <h3>Options</h3>
        <ul class="shop-option-list">
          <li><i class="bx bx-check-circle"></i><span>Nouveautes de la semaine</span></li>
          <li><i class="bx bx-check-circle"></i><span>Produits en promotion</span></li>
          <li><i class="bx bx-check-circle"></i><span>Livraison express disponible</span></li>
          <li><i class="bx bx-check-circle"></i><span>Stock limite en priorite</span></li>
        </ul>
      </div>

      <a class="shop-filter-cta" href="<%= buildShopHref({ q: '', category: '', sort: 'popular', promo: false, size: '', price: '' }) %>">Reinitialiser les filtres</a>
    </aside>

    <div class="shop-results">
      <header class="shop-results__head">
        <div class="shop-results__intro">
          <p class="shop-results__kicker">Listing produits</p>
          <h2 class="shop-results__title">Selection complete toutes categories</h2>
          <p class="shop-results__count"><strong><%= filteredProducts %></strong> produits visibles sur <strong><%= totalProducts %></strong> references.</p>

          <% if (selectedQuery) { %>
          <p class="shop-results__query-badge">
            <i class="bx bx-search-alt-2"></i>
            <span>Recherche: "<%= selectedQuery %>"</span>
          </p>
          <% } %>

          <form class="shop-results__search" action="/shop" method="get" role="search">
            <% if (selectedCategory) { %>
            <input type="hidden" name="category" value="<%= selectedCategory %>" />
            <% } %>
            <% if (selectedSort && selectedSort !== 'popular') { %>
            <input type="hidden" name="sort" value="<%= selectedSort %>" />
            <% } %>
            <% if (promoOnly) { %>
            <input type="hidden" name="promo" value="true" />
            <% } %>
            <% if (selectedSize) { %>
            <input type="hidden" name="size" value="<%= selectedSize %>" />
            <% } %>
            <% if (selectedPrice) { %>
            <input type="hidden" name="price" value="<%= selectedPrice %>" />
            <% } %>

            <div class="shop-results__search-field">
              <i class="bx bx-search-alt-2" aria-hidden="true"></i>
              <input
                id="shop-search-input"
                type="search"
                name="q"
                value="<%= selectedQuery %>"
                placeholder="Rechercher un produit, une categorie, un SKU..."
                maxlength="120"
                aria-label="Rechercher un produit"
              />
              <button type="submit">Rechercher</button>
            </div>
            <% if (selectedQuery) { %>
            <a class="shop-results__search-reset" href="<%= buildShopHref({ q: '' }) %>">Effacer la recherche</a>
            <% } %>
          </form>
        </div>

        <div class="shop-results__controls">
          <button
            class="shop-mobile-filter-toggle"
            type="button"
            data-shop-filter-toggle
            aria-controls="shop-mobile-filters"
            aria-expanded="false"
          >
            <i class="bx bx-filter-alt"></i>
            <span>Filtres</span>
          </button>

          <div class="shop-sort-overlay">
            <div class="shop-sort" aria-label="Tri rapide">
              <a class="shop-sort__item <%= selectedSort === 'popular' ? 'is-active' : '' %>" href="<%= buildShopHref({ sort: 'popular' }) %>">Populaire</a>
              <a class="shop-sort__item <%= selectedSort === 'new' ? 'is-active' : '' %>" href="<%= buildShopHref({ sort: 'new' }) %>">Nouveautes</a>
              <a class="shop-sort__item <%= selectedSort === 'price-low' ? 'is-active' : '' %>" href="<%= buildShopHref({ sort: 'price-low' }) %>">Prix croissant</a>
              <a class="shop-sort__item <%= selectedSort === 'price-high' ? 'is-active' : '' %>" href="<%= buildShopHref({ sort: 'price-high' }) %>">Prix decroissant</a>
            </div>
          </div>
        </div>
      </header>

      <div class="shop-grid">
        <% if (!products.length) { %>
        <article class="shop-grid__empty">
          <p>Aucun produit ne correspond aux filtres actuels.</p>
          <a href="<%= buildShopHref({ q: '', category: '', sort: 'popular', promo: false, size: '', price: '' }) %>">Voir tout le catalogue</a>
        </article>
        <% } %>

        <% products.forEach((product, index) => { %>
        <% const categoryIcon = getCategoryIcon(product.category); %>
        <article class="shop-product">
          <a
            class="shop-product__media shop-product__media--<%= product.palette %><%= product.image ? ' has-image' : '' %>"
            href="<%= product.href %>"
            aria-label="Voir <%= product.name %>"
          >
            <% if (product.image) { %>
            <img
              class="shop-product__image"
              src="<%= product.image %>"
              alt="<%= product.name %>"
              loading="lazy"
              decoding="async"
            />
            <% } %>
            <span class="shop-product__tag"><%= product.tag %></span>
            <span class="shop-product__status shop-product__status--<%= product.statusTone %>"><%= product.status %></span>
            <span class="shop-product__sku"><%= product.sku %></span>
          </a>

          <button
            class="shop-product__wish"
            type="button"
            data-favorite-btn
            data-product-slug="<%= product.slug || '' %>"
            aria-pressed="<%= product.isFavorite ? 'true' : 'false' %>"
            aria-label="Ajouter <%= product.name %> aux favoris"
          >
            <i class="bx <%= product.isFavorite ? 'bxs-heart' : 'bx-heart' %>"></i>
          </button>

          <div class="shop-product__body">
            <div class="shop-product__meta">
              <span class="shop-product__category-chip">
                <i class="bx <%= categoryIcon %>"></i>
                <span><%= product.category %></span>
              </span>
              <span class="shop-product__age"><%= product.age %></span>
            </div>

            <a class="shop-product__details" href="<%= product.href %>">
              <h3 class="shop-product__name"><%= product.name %></h3>
            </a>

            <div class="shop-product__prices">
              <span class="shop-product__price-current"><%= product.price %></span>
              <% if (product.oldPrice) { %>
              <span class="shop-product__price-old"><%= product.oldPrice %></span>
              <% } %>
            </div>

            <div class="shop-product__foot">
              <p class="shop-product__rating">
                <i class="bx bxs-star"></i>
                <span><%= product.rating %></span>
              </p>
              <div class="shop-product__actions">
                <a class="shop-product__btn shop-product__btn--ghost" href="<%= product.href %>">Details</a>
                <a class="shop-product__btn shop-product__btn--primary" data-add-to-cart data-product-slug="<%= product.slug || '' %>" href="/cart">
                  <i class="bx bx-cart-add"></i>
                  <span>Panier</span>
                </a>
              </div>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="shop-category-spotlight" aria-label="Categories en avant">
    <% if (!featuredCategories.length) { %>
    <article class="shop-grid__empty">
      <p>Les categories seront visibles apres ajout des premiers produits.</p>
    </article>
    <% } %>

    <% featuredCategories.forEach((category) => { %>
    <a class="shop-category-card shop-category-card--<%= category.tone %>" href="<%= category.href %>">
      <span class="shop-category-card__kicker">Categorie</span>
      <h2><%= category.title %></h2>
      <p><%= category.text %></p>
      <span class="shop-category-card__cta">
        <span>Explorer</span>
        <i class="bx bx-right-arrow-alt"></i>
      </span>
    </a>
    <% }) %>
  </section>

  <section class="shop-final-cta" aria-label="Call to action shop">
    <div>
      <p class="shop-final-cta__kicker">Rose&amp;Bleu marketplace</p>
      <h2 class="shop-final-cta__title">Besoin d aller plus loin ? Explore le catalogue complet</h2>
      <p class="shop-final-cta__text">
        Continue la navigation par categorie, trie par prix ou garde tes coups de coeur dans ta wishlist.
      </p>
    </div>
    <div class="shop-final-cta__actions">
      <a class="btn btn-primary" href="/shop">Catalogue complet</a>
      <a class="btn btn-outline" href="/favoris">Voir mes favoris</a>
    </div>
  </section>
</section>
