<section class="user-page page-shop">
  <%
    const quickFilters = [
      { label: "Tout le catalogue", href: "/shop", active: true },
      { label: "Nouveautes", href: "/shop?sort=new" },
      { label: "Bebes", href: "/shop?category=bebes" },
      { label: "Filles", href: "/shop?category=filles" },
      { label: "Garcons", href: "/shop?category=garcons" },
      { label: "Chaussures", href: "/shop?category=chaussures" },
      { label: "Accessoires", href: "/shop?category=accessoires" },
      { label: "Promotions", href: "/shop?promo=true" },
    ];

    const serviceHighlights = [
      {
        icon: "bx-rocket",
        title: "Expedition 24-48h",
        text: "Preparation rapide pour toutes les commandes validees.",
      },
      {
        icon: "bx-check-shield",
        title: "Paiement securise",
        text: "Transactions protegees et verification anti-fraude.",
      },
      {
        icon: "bx-refresh",
        title: "Retours faciles",
        text: "14 jours pour echanger ou retourner sereinement.",
      },
      {
        icon: "bx-support",
        title: "Support disponible",
        text: "Assistance client du lundi au samedi.",
      },
    ];

    const categories = [
      { label: "Tout", count: 132, href: "/shop" },
      { label: "Bebes", count: 22, href: "/shop?category=bebes" },
      { label: "Filles", count: 26, href: "/shop?category=filles" },
      { label: "Garcons", count: 24, href: "/shop?category=garcons" },
      { label: "Chaussures", count: 18, href: "/shop?category=chaussures" },
      { label: "Accessoires", count: 20, href: "/shop?category=accessoires" },
      { label: "Mixte", count: 22, href: "/shop?category=mixte" },
    ];

    const products = [
      {
        name: "Robe Petales Soft",
        category: "Filles",
        age: "3-8 ans",
        price: "29,90 EUR",
        oldPrice: "39,90 EUR",
        rating: "4.8",
