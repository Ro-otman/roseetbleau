<section class="admin-page admin-edit-product">
  <section class="admin-panel">
    <%
      const values = formData || {};
      const feedback = productFeedback || null;
      const categories = Array.isArray(categoryOptions) ? categoryOptions : [];
      const selectedCategory = values.category || "";
      const selectedStatus = values.status || "active";
      const selectedVisibility = values.visibility || "public";
    %>

    <header class="admin-panel__head">
      <h2>Modifier produit #<%= Number(productId || 0) %></h2>
      <a href="/admin/produits">Retour catalogue</a>
    </header>

    <% if (feedback) { %>
    <div class="admin-feedback admin-feedback--<%= feedback.tone || "info" %>" role="status">
      <p class="admin-feedback__title"><%= feedback.title %></p>
      <p class="admin-feedback__message"><%= feedback.message %></p>
    </div>
    <% } %>

    <form class="admin-form" action="/admin/produits/<%= Number(productId || 0) %>/edit" method="post">
      <div class="admin-form-grid admin-form-grid--two">
        <div class="admin-field">
          <label for="product-name">Nom produit</label>
          <input
            id="product-name"
            name="name"
            type="text"
            placeholder="Ex: Robe Petales Soft"
            value="<%= values.name || "" %>"
            required
          />
        </div>

        <div class="admin-field">
          <label for="product-sku">Reference SKU</label>
          <input
            id="product-sku"
            name="sku"
            type="text"
            placeholder="RB-NEW-001"
            value="<%= values.sku || "" %>"
            required
          />
        </div>
      </div>

      <div class="admin-form-grid admin-form-grid--three">
        <div class="admin-field">
          <label for="product-category">Categorie</label>
          <select id="product-category" name="category" required>
            <option value="">Selectionner</option>
            <% categories.forEach((item) => { %>
            <option value="<%= item.slug %>" <%= selectedCategory === item.slug ? "selected" : "" %>>
              <%= item.name %>
            </option>
            <% }) %>
          </select>
        </div>

        <div class="admin-field">
          <label for="product-price">Prix</label>
          <input
            id="product-price"
            name="price"
            type="number"
            step="0.01"
            placeholder="29.90"
            value="<%= values.price || "" %>"
            required
          />
        </div>

        <div class="admin-field">
          <label for="product-stock">Stock total</label>
          <input
            id="product-stock"
            name="stock"
            type="number"
            placeholder="10"
            value="<%= values.stock || "" %>"
            required
          />
        </div>
      </div>

      <div class="admin-form-grid admin-form-grid--two">
        <div class="admin-field">
          <label for="product-status">Statut</label>
          <select id="product-status" name="status" required>
            <option value="active" <%= selectedStatus === "active" ? "selected" : "" %>>Actif</option>
            <option value="draft" <%= selectedStatus === "draft" ? "selected" : "" %>>Brouillon</option>
            <option value="archived" <%= selectedStatus === "archived" ? "selected" : "" %>>Archive</option>
          </select>
        </div>

        <div class="admin-field">
          <label for="product-visibility">Visibilite</label>
          <select id="product-visibility" name="visibility" required>
            <option value="public" <%= selectedVisibility === "public" ? "selected" : "" %>>Public</option>
            <option value="private" <%= selectedVisibility === "private" ? "selected" : "" %>>Prive</option>
          </select>
        </div>
      </div>

      <div class="admin-field">
        <label for="product-description">Description</label>
        <textarea
          id="product-description"
          name="description"
          rows="5"
          placeholder="Description courte et benefices produit..."
        ><%= values.description || "" %></textarea>
      </div>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">
          <i class="bx bx-save"></i>
          <span>Enregistrer</span>
        </button>
        <a href="/admin/produits" class="admin-btn admin-btn--ghost">Retour</a>
      </div>
    </form>

    <form
      class="admin-form-actions"
      action="/admin/produits/<%= Number(productId || 0) %>/delete"
      method="post"
      onsubmit="return window.confirm('Supprimer ce produit ? Cette action est irreversible.');"
    >
      <button type="submit" class="admin-btn admin-btn--ghost">
        <i class="bx bx-trash"></i>
        <span>Supprimer ce produit</span>
      </button>
    </form>
  </section>
</section>
