<%
  const overview = adminProductsOverview || {};
  const filters = overview.filters || {};
  const products = Array.isArray(overview.products) ? overview.products : [];
  const summary = overview.summary || {};
  const qValue = String(filters.q || "");
  const stockValue = String(filters.stock || "all");
  const generatedLabel = String(overview.generatedLabel || "");
  const filteredProducts = Number(summary.filteredProducts || products.length || 0);
  const stockFilters = [
    { key: "all", label: "Tous" },
    { key: "active", label: "Actifs" },
    { key: "low", label: "Stock limite" },
    { key: "out", label: "Rupture" },
  ];

  const buildFilterHref = (stockKey) => {
    const params = [];
    if (qValue) {
      params.push(`q=${encodeURIComponent(qValue)}`);
    }
    if (stockKey && stockKey !== "all") {
      params.push(`stock=${encodeURIComponent(stockKey)}`);
    }
    return params.length ? `/admin/produits?${params.join("&")}` : "/admin/produits";
  };
%>

<section
  class="admin-page admin-products"
  data-admin-products
  data-products-api="/admin/api/products-overview"
  data-products-filter-q="<%= qValue %>"
  data-products-filter-stock="<%= stockValue %>"
>
  <section class="admin-panel admin-products-hero" aria-label="Vue produits">
    <div class="admin-products-hero__content">
      <p class="admin-products-hero__kicker">Catalogue visuel</p>
      <h2 class="admin-products-hero__title">
        Gere tes produits avec un apercu photo direct
      </h2>
      <p class="admin-products-hero__lead">
        Chaque fiche affiche l image, le stock et les infos cles pour modifier
        rapidement le bon produit sans confusion.
      </p>
    </div>

    <div class="admin-products-hero__stats">
      <article class="admin-products-stat">
        <p class="admin-products-stat__value" data-products-total>
          <%= Number(summary.totalProducts || 0) %>
        </p>
        <p class="admin-products-stat__label">Produits total</p>
      </article>
      <article class="admin-products-stat">
        <p class="admin-products-stat__value" data-products-active>
          <%= Number(summary.activeProducts || 0) %>
        </p>
        <p class="admin-products-stat__label">Produits actifs</p>
      </article>
      <article class="admin-products-stat">
        <p class="admin-products-stat__value" data-products-watch>
          <%= Number(summary.watchProducts || 0) %>
        </p>
        <p class="admin-products-stat__label">A surveiller</p>
      </article>
    </div>
  </section>

  <section class="admin-panel">
    <header class="admin-panel__head">
      <h2>
        Catalogue produits
        (<span data-products-filtered-count><%= filteredProducts %></span>)
      </h2>
      <a href="/admin/ajoutproduit">Ajouter un produit</a>
    </header>

    <p class="admin-panel__lead admin-products__updated" data-products-updated-at>
      <%= generatedLabel ? `Mise a jour: ${generatedLabel}` : "" %>
    </p>

    <div class="admin-toolbar">
      <form class="admin-search" action="/admin/produits" method="get" role="search">
        <i class="bx bx-search-alt-2"></i>
        <input
          type="search"
          name="q"
          placeholder="Rechercher un produit..."
          value="<%= qValue %>"
          data-products-search-input
        />
        <% if (stockValue !== "all") { %>
        <input type="hidden" name="stock" value="<%= stockValue %>" />
        <% } %>
      </form>
      <div class="admin-toolbar__filters">
        <% stockFilters.forEach((item) => { %>
        <a
          href="<%= buildFilterHref(item.key) %>"
          class="<%= stockValue === item.key ? 'is-active' : '' %>"
          data-products-filter-link="<%= item.key %>"
          <% if (stockValue === item.key) { %>aria-current="page"<% } %>
        >
          <%= item.label %>
        </a>
        <% }) %>
      </div>
    </div>

    <div class="admin-product-grid" aria-label="Liste produits visuelle" data-products-grid>
      <% if (!products.length) { %>
      <p class="admin-products-empty" data-products-empty>
        Aucun produit pour ce filtre.
      </p>
      <% } %>

      <% products.forEach((item) => { %>
      <article class="admin-product-card">
        <a
          class="admin-product-card__media"
          href="<%= item.href || '/admin/produits' %>"
          aria-label="Modifier <%= item.name %>"
        >
          <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy" />
          <span class="admin-badge admin-badge--<%= item.tone %>"><%= item.status %></span>
          <span class="admin-product-card__sku"><%= item.sku %></span>
        </a>

        <div class="admin-product-card__body">
          <p class="admin-product-card__category"><%= item.category %></p>
          <h3 class="admin-product-card__name"><%= item.name %></h3>

          <div class="admin-product-card__prices">
            <span class="admin-product-card__price-current"><%= item.price %></span>
            <% if (item.oldPrice) { %>
            <span class="admin-product-card__price-old"><%= item.oldPrice %></span>
            <% } %>
          </div>

          <div class="admin-product-card__stock">
            <span><strong><%= Number(item.stock || 0) %></strong> en stock</span>
            <span><%= item.updated %></span>
          </div>

          <div class="admin-product-card__actions">
            <a href="<%= item.href || '/admin/produits' %>"><i class="bx bx-edit"></i><span>Modifier</span></a>
            <form
              action="/admin/produits/<%= Number(item.id || 0) %>/delete"
              method="post"
              onsubmit="return window.confirm('Supprimer ce produit ? Cette action est irreversible.');"
            >
              <button type="submit"><i class="bx bx-trash"></i><span>Supprimer</span></button>
            </form>
          </div>
        </div>
      </article>
      <% }) %>
    </div>
  </section>
</section>
