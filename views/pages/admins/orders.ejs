<%
  const overview = adminOrdersOverview || {};
  const feedback = ordersFeedback || null;
  const filters = overview.filters || {};
  const summary = overview.summary || {};
  const orders = Array.isArray(overview.orders) ? overview.orders : [];
  const qValue = String(filters.q || "");
  const statusValue = String(filters.status || "all");
  const generatedLabel = String(overview.generatedLabel || "");
  const filteredOrders = Number(summary.filteredOrders || orders.length || 0);
  const orderFilters = [
    { key: "all", label: "Toutes" },
    { key: "review", label: "A verifier" },
    { key: "processing", label: "En preparation" },
    { key: "shipped", label: "Expediees" },
  ];

  const buildFilterHref = (statusKey) => {
    const params = [];
    if (qValue) {
      params.push(`q=${encodeURIComponent(qValue)}`);
    }
    if (statusKey && statusKey !== "all") {
      params.push(`status=${encodeURIComponent(statusKey)}`);
    }
    return params.length ? `/admin/orders?${params.join("&")}` : "/admin/orders";
  };

  const currentListPath = buildFilterHref(statusValue);
%>

<section
  class="admin-page admin-orders"
  data-admin-orders
  data-orders-api="/admin/api/orders-overview"
  data-orders-filter-q="<%= qValue %>"
  data-orders-filter-status="<%= statusValue %>"
>
  <section class="admin-panel">
    <header class="admin-panel__head">
      <h2>
        Suivi des commandes
        (<span data-orders-filtered-count><%= filteredOrders %></span>)
      </h2>
      <a href="/admin/orders">Exporter CSV</a>
    </header>

    <% if (feedback) { %>
    <div class="admin-feedback admin-feedback--<%= feedback.tone || "info" %>" role="status">
      <p class="admin-feedback__title"><%= feedback.title %></p>
      <p class="admin-feedback__message"><%= feedback.message %></p>
    </div>
    <% } %>

    <p class="admin-panel__lead" data-orders-updated-at>
      <%= generatedLabel ? `Mise a jour: ${generatedLabel}` : "" %>
    </p>

    <div class="admin-toolbar">
      <form class="admin-search" action="/admin/orders" method="get" role="search">
        <i class="bx bx-search-alt-2"></i>
        <input
          type="search"
          name="q"
          placeholder="Rechercher une commande..."
          value="<%= qValue %>"
          data-orders-search-input
        />
        <% if (statusValue !== "all") { %>
        <input type="hidden" name="status" value="<%= statusValue %>" />
        <% } %>
      </form>
      <div class="admin-toolbar__filters">
        <% orderFilters.forEach((item) => { %>
        <a
          href="<%= buildFilterHref(item.key) %>"
          class="<%= statusValue === item.key ? 'is-active' : '' %>"
          data-orders-filter-link="<%= item.key %>"
          <% if (statusValue === item.key) { %>aria-current="page"<% } %>
        >
          <%= item.label %>
        </a>
        <% }) %>
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Commande</th>
            <th>Client</th>
            <th>Date</th>
            <th>Total</th>
            <th>Paiement</th>
            <th>Statut</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody data-orders-table-body>
          <% if (!orders.length) { %>
          <tr>
            <td colspan="7">Aucune commande pour ce filtre.</td>
          </tr>
          <% } %>

          <% orders.forEach((item) => { %>
          <tr>
            <td data-label="Commande"><%= item.orderNumber %></td>
            <td data-label="Client"><%= item.customer %></td>
            <td data-label="Date"><%= item.date %></td>
            <td data-label="Total"><%= item.total %></td>
            <td data-label="Paiement"><%= item.payment %></td>
            <td data-label="Statut"><span class="admin-badge admin-badge--<%= item.tone %>"><%= item.status %></span></td>
            <td data-label="Action">
              <div class="admin-row-actions">
                <a href="<%= item.href || '/admin/orders' %>">Details</a>
                <% if (item.canUpdate && item.nextStatus) { %>
                <form action="/admin/orders/<%= Number(item.id || 0) %>/status" method="post">
                  <input type="hidden" name="status" value="<%= item.nextStatus %>" />
                  <input type="hidden" name="returnTo" value="<%= currentListPath %>" />
                  <button type="submit"><%= item.nextStatusLabel ? `Passer ${item.nextStatusLabel}` : "Mettre a jour" %></button>
                </form>
                <% } else { %>
                <button type="button" disabled>Finalisee</button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</section>
