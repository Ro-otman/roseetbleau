<section
  class="admin-page admin-dashboard"
  data-admin-dashboard
  data-dashboard-api="/admin/api/dashboard-stats"
>
  <%
    const dashboard = adminDashboard || {};
    const stats = Array.isArray(dashboard.stats) ? dashboard.stats : [];
    const weeklyPerformance = Array.isArray(dashboard.weeklyPerformance)
      ? dashboard.weeklyPerformance
      : [];
    const categoryDistribution = Array.isArray(dashboard.categoryDistribution)
      ? dashboard.categoryDistribution
      : [];
    const recentOrders = Array.isArray(dashboard.recentOrders) ? dashboard.recentOrders : [];
    const dashboardUpdatedAt = String(dashboard.generatedLabel || "");

    const quickLinks = [
      { href: "/admin/ajoutproduit", title: "Ajouter produit", text: "Creer une fiche complete en quelques minutes.", icon: "bx-plus-circle" },
      { href: "/admin/orders", title: "Suivre commandes", text: "Verifier les commandes en attente et urgentes.", icon: "bx-receipt" },
      { href: "/admin/users", title: "Gerer users", text: "Consulter les comptes clients et leur activite.", icon: "bx-user" },
      { href: "/admin/produits", title: "Mettre a jour stock", text: "Ajuster les quantites et les disponibilites.", icon: "bx-package" },
    ];
  %>

  <section class="admin-stats-grid" aria-label="Statistiques principales">
    <% stats.forEach((item) => { %>
    <article class="admin-stat-card" data-dashboard-kpi="<%= item.id %>">
      <p class="admin-stat-card__label"><%= item.label %></p>
      <p class="admin-stat-card__value" data-dashboard-kpi-value="<%= item.id %>"><%= item.value %></p>
      <p class="admin-stat-card__trend <%= item.trendTone === 'down' ? 'is-down' : 'is-up' %>">
        <i
          class="bx <%= item.trendIcon || (item.trendTone === 'down' ? 'bx-trending-down' : 'bx-trending-up') %>"
          data-dashboard-kpi-trend-icon="<%= item.id %>"
        ></i>
        <span data-dashboard-kpi-trend="<%= item.id %>"><%= item.trend %></span>
      </p>
    </article>
    <% }) %>
  </section>

  <section class="admin-grid-2" aria-label="Vue performance">
    <article class="admin-panel">
      <header class="admin-panel__head">
        <h2>Performance hebdomadaire</h2>
        <a href="/admin/orders">Voir details</a>
      </header>
      <p class="admin-panel__lead">
        Evolution des ventes des 7 derniers jours.
        <% if (dashboardUpdatedAt) { %>
        <span class="admin-dashboard__updated-at" data-dashboard-updated-at>
          Mise a jour: <%= dashboardUpdatedAt %>
        </span>
        <% } else { %>
        <span class="admin-dashboard__updated-at" data-dashboard-updated-at></span>
        <% } %>
      </p>

      <div class="admin-mini-chart" role="img" aria-label="Graphique des ventes" data-dashboard-weekly-chart>
        <% weeklyPerformance.forEach((item) => { %>
        <span
          style="--h: <%= item.height %>%"
          title="<%= item.label %> - <%= item.valueLabel || '' %>"
        ></span>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <header class="admin-panel__head">
        <h2>Repartition catalogue</h2>
        <a href="/admin/produits">Gerer</a>
      </header>
      <p class="admin-panel__lead">Poids des categories dans le stock actif.</p>
      <ul class="admin-distribution" data-dashboard-distribution>
        <% categoryDistribution.forEach((item) => { %>
        <li>
          <span><%= item.name %></span>
          <strong><%= item.percent %>%</strong>
        </li>
        <% }) %>
      </ul>
    </article>
  </section>

  <section class="admin-panel" aria-label="Actions rapides">
    <header class="admin-panel__head">
      <h2>Actions rapides</h2>
    </header>
    <div class="admin-quick-grid">
      <% quickLinks.forEach((item) => { %>
      <a class="admin-quick-card" href="<%= item.href %>">
        <i class="bx <%= item.icon %>"></i>
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </a>
      <% }) %>
    </div>
  </section>

  <section class="admin-panel" aria-label="Dernieres commandes">
    <header class="admin-panel__head">
      <h2>Dernieres commandes</h2>
      <a href="/admin/orders">Tout voir</a>
    </header>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Commande</th>
            <th>Client</th>
            <th>Montant</th>
            <th>Statut</th>
          </tr>
        </thead>
        <tbody data-dashboard-recent-orders>
          <% if (!recentOrders.length) { %>
          <tr>
            <td colspan="4">Aucune commande recente pour le moment.</td>
          </tr>
          <% } %>

          <% recentOrders.forEach((item) => { %>
          <tr>
            <td data-label="Commande"><%= item.id %></td>
            <td data-label="Client"><%= item.client %></td>
            <td data-label="Montant"><%= item.amount %></td>
            <td data-label="Statut"><span class="admin-badge admin-badge--<%= item.tone %>"><%= item.status %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</section>
